@page
@model TaskManager.Pages.Tasks.DeleteModel
@{
    ViewData["Title"] = "Delete task";
}

<h1>Delete task</h1>

@if (Model.TaskItem is null)
{
    <div class="alert alert-warning" role="alert">
        Task not found.
    </div>
}
else
{
    <div class="alert alert-danger" role="alert">
        Are you sure you want to delete this task?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.TaskItem.Title</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.TaskItem.Description</dd>

        <dt class="col-sm-2">Tags</dt>
        <dd class="col-sm-10">@string.Join(", ", Model.TaskItem.Tags)</dd>
    </dl>

    <form method="post">
        <input asp-for="TaskItem!.Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Tasks/Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
}
