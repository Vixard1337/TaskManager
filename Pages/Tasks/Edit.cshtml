@page
@model TaskManager.Pages.Tasks.EditModel
@{
    ViewData["Title"] = "Edit task";
}

<h1>Edit task</h1>

<form method="post" class="mt-3">
    <input asp-for="TaskItem.Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TaskItem.Title" class="form-label"></label>
        <input asp-for="TaskItem.Title" class="form-control" />
        <span asp-validation-for="TaskItem.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TaskItem.Description" class="form-label"></label>
        <textarea asp-for="TaskItem.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="TaskItem.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TaskItem.UserId" class="form-label">Assigned user</label>
        <select asp-for="TaskItem.UserId" class="form-select">
            <option value="">Select user</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.Name @user.Surname</option>
            }
        </select>
        <span asp-validation-for="TaskItem.UserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TagsInput" class="form-label">Tags (comma separated)</label>
        <input asp-for="TagsInput" class="form-control" />
        <span asp-validation-for="TagsInput" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="/Tasks/Index" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
