@page
@model TaskManager.Pages.Tasks.CreateModel
@{
    ViewData["Title"] = "Add task";
}

<h1>Add task</h1>

@if (!Model.Users.Any())
{
    <div class="alert alert-warning" role="alert">
        You need at least one user before creating a task.
        <a asp-page="/Users/Create" class="alert-link">Create user</a>
    </div>
}

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TaskItem.Title" class="form-label"></label>
        <input asp-for="TaskItem.Title" class="form-control" />
        <span asp-validation-for="TaskItem.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TaskItem.Description" class="form-label"></label>
        <textarea asp-for="TaskItem.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="TaskItem.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TaskItem.UserId" class="form-label">Assigned user</label>
        <select asp-for="TaskItem.UserId" class="form-select" disabled="@(!Model.Users.Any())">
            <option value="">Select user</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.Name @user.Surname</option>
            }
        </select>
        <span asp-validation-for="TaskItem.UserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TagsInput" class="form-label">Tags (comma separated)</label>
        <input asp-for="TagsInput" class="form-control" placeholder="study, project" />
        <span asp-validation-for="TagsInput" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary" disabled="@(!Model.Users.Any())">Save</button>
    <a asp-page="/Tasks/Index" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
