@page
@model TaskManager.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Tasks</h1>
    <a asp-page="/Tasks/Create" class="btn btn-primary">Add task</a>
</div>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info" role="alert">
        No tasks found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Tags</th>
                <th>Done</th>
                <th>UserId</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var task in Model.Tasks)
        {
            <tr>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@string.Join(", ", task.Tags)</td>
                <td>@(task.IsDone ? "Yes" : "No")</td>
                <td>@task.UserId</td>
                <td>
                    <form method="post" asp-page-handler="ToggleDone" class="d-inline">
                        <input type="hidden" name="id" value="@task.Id" />
                        <button type="submit" class="btn btn-sm @(task.IsDone ? "btn-outline-warning" : "btn-outline-success")">
                            @(task.IsDone ? "Undo" : "Done")
                        </button>
                    </form>
                    <a asp-page="/Tasks/Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-page="/Tasks/Delete" asp-route-id="@task.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
