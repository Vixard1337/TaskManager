@page
@model TaskManager.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tasks (Admin)";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Tasks (Admin)</h1>
    <a asp-page="/Tasks/Create" class="btn btn-primary">Add task</a>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-sm-6 col-md-4">
        <label asp-for="Tag" class="form-label">Filter by tag</label>
        <input asp-for="Tag" class="form-control" placeholder="project" />
    </div>
    <div class="col-sm-6 col-md-4">
        <label asp-for="Title" class="form-label">Search by title</label>
        <input asp-for="Title" class="form-control" placeholder="task title" />
    </div>
    <div class="col-sm-6 col-md-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            <option value="all">All</option>
            <option value="done">Done</option>
            <option value="notdone">Not done</option>
        </select>
    </div>
    <div class="col-sm-6 col-md-3">
        <label asp-for="UserId" class="form-label">User</label>
        <select asp-for="UserId" class="form-select">
            <option value="">All users</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.Name @user.Surname</option>
            }
        </select>
    </div>
    <div class="col-sm-6 col-md-3">
        <label asp-for="Sort" class="form-label">Sort</label>
        <select asp-for="Sort" class="form-select">
            <option value="status">Not done first</option>
            <option value="titleasc">Title A-Z</option>
            <option value="titledesc">Title Z-A</option>
            <option value="userasc">User A-Z</option>
            <option value="userdesc">User Z-A</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a asp-page="/Tasks/Index" class="btn btn-outline-secondary ms-1">Clear</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Tag) || !string.IsNullOrWhiteSpace(Model.Title) || Model.Status != "all" || Model.Sort != "status" || !string.IsNullOrWhiteSpace(Model.UserId))
{
    <p class="text-muted mb-2">
        Active filters:
        @if (!string.IsNullOrWhiteSpace(Model.Tag))
        {
            <span class="badge text-bg-light border me-1">Tag: @Model.Tag</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Title))
        {
            <span class="badge text-bg-light border me-1">Title: @Model.Title</span>
        }
        @if (Model.Status != "all")
        {
            <span class="badge text-bg-light border">Status: @Model.Status</span>
        }
        @if (Model.Sort != "status")
        {
            <span class="badge text-bg-light border ms-1">Sort: @Model.Sort</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.UserId))
        {
            <span class="badge text-bg-light border ms-1">User: @Model.GetUserDisplayName(Model.UserId)</span>
        }
    </p>
}

<p class="text-muted small mb-3">
    <strong>Done/Undo</strong> changes only task status. <strong>Delete</strong> opens a confirmation page before removing data.
</p>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info" role="alert">
        No tasks found.
    </div>
}
else
{
    <div class="table-scroll-container">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Tags</th>
                    <th>Done</th>
                    <th>User</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Description</td>
                    <td>@string.Join(", ", task.Tags)</td>
                    <td>@(task.IsDone ? "Yes" : "No")</td>
                    <td>@Model.GetUserDisplayName(task.UserId)</td>
                    <td class="text-nowrap">
                        <form method="post" asp-page-handler="ToggleDone" class="d-inline me-1">
                            <input type="hidden" name="id" value="@task.Id" />
                            <input type="hidden" name="tag" value="@Model.Tag" />
                            <input type="hidden" name="status" value="@Model.Status" />
                            <input type="hidden" name="title" value="@Model.Title" />
                            <input type="hidden" name="sort" value="@Model.Sort" />
                            <input type="hidden" name="userId" value="@Model.UserId" />
                            <button type="submit" class="btn btn-sm @(task.IsDone ? "btn-outline-warning" : "btn-outline-success")">
                                @(task.IsDone ? "Undo" : "Done")
                            </button>
                        </form>
                        <a asp-page="/Tasks/Edit" asp-route-id="@task.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <a asp-page="/Tasks/Delete" asp-route-id="@task.Id" class="btn btn-sm btn-outline-danger">Delete...</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
