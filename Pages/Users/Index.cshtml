@page
@model TaskManager.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Users</h1>
    <a asp-page="/Users/Create" class="btn btn-primary">Add user</a>
</div>

@if (!Model.Users.Any())
{
    <div class="alert alert-info" role="alert">
        No users found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Surname</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Surname</td>
            </tr>
        }
        </tbody>
    </table>
}
