@page
@model TaskManager.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Users (Admin)</h1>
    <a asp-page="/Users/Create" class="btn btn-primary">Add user</a>
</div>

@if (!Model.Users.Any())
{
    <div class="alert alert-info" role="alert">
        No users found.
    </div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Surname</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Surname</td>
                <td class="text-nowrap">
                    <a asp-page="/Users/Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                    <a asp-page="/Users/Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Delete...</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
