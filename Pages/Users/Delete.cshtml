@page
@model TaskManager.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Delete user";
}

<h1>Delete user</h1>

@if (Model.User is null)
{
    <div class="alert alert-warning" role="alert">
        User not found.
    </div>
}
else
{
    <div class="alert alert-danger" role="alert">
        Are you sure you want to delete this user?
    </div>

    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.User.Name</dd>

        <dt class="col-sm-2">Surname</dt>
        <dd class="col-sm-10">@Model.User.Surname</dd>
    </dl>

    <form method="post">
        <input asp-for="User!.Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="/Users/Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
}
