@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="p-4 p-md-5 rounded-4 mb-4" style="background: linear-gradient(135deg, #312e81 0%, #4f46e5 100%); color: #fff;">
    <h1 class="display-6 mb-2">Task Manager Dashboard</h1>
    <p class="mb-0 opacity-75">Manage users and tasks with filters, sorting, and quick status updates.</p>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="border rounded-4 p-4 h-100 bg-white">
            <h2 class="h5 mb-2">Tasks</h2>
            <p class="text-muted mb-3">View, filter, sort, and update task status in one place.</p>
            <a asp-page="/Tasks/Index" class="btn btn-primary">Open tasks</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="border rounded-4 p-4 h-100 bg-white">
            <h2 class="h5 mb-2">Users</h2>
            <p class="text-muted mb-3">Create and manage users assigned to tasks.</p>
            <a asp-page="/Users/Index" class="btn btn-outline-primary">Open users</a>
        </div>
    </div>
</div>
